{
  "name": "cropchain-smart-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for CropChain blockchain crop tracking system",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "compile": "cd smart-contracts && npx hardhat compile",
    "test": "cd smart-contracts && npx hardhat test",
    "test:ci": "cd smart-contracts && npx hardhat test",
    "deploy:localhost": "cd smart-contracts && npx hardhat run scripts/deploy.js --network localhost",
    "deploy:mumbai": "cd smart-contracts && npx hardhat run scripts/deploy.js --network mumbai",
    "deploy:polygon": "cd smart-contracts && npx hardhat run scripts/deploy.js --network polygon",
    "deploy:sepolia": "cd smart-contracts && npx hardhat run scripts/deploy.js --network sepolia",
    "verify:mumbai": "cd smart-contracts && npx hardhat verify --network mumbai",
    "verify:polygon": "cd smart-contracts && npx hardhat verify --network polygon",
    "node": "cd smart-contracts && npx hardhat node",
    "clean": "cd smart-contracts && npx hardhat clean",
    "setup:ai": "node scripts/setup-ai-chatbot.js"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "solidity",
    "hardhat",
    "supply-chain",
    "agriculture"
  ],
  "author": "CropChain Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.4",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.9",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@typechain/ethers-v6": "^0.4.3",
    "@typechain/hardhat": "^8.0.3",
    "@types/chai": "^4.3.6",
    "@types/mocha": "^10.0.2",
    "chai": "^4.3.8",
    "ethers": "^6.7.1",
    "hardhat": "^2.17.1",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.1",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "overrides": {
    "hardhat": "$hardhat",
    "@nomicfoundation/hardhat-ethers": "$@nomicfoundation/hardhat-ethers",
    "@nomicfoundation/hardhat-verify": "$@nomicfoundation/hardhat-verify",
    "@nomicfoundation/hardhat-ignition-ethers": "$@nomicfoundation/hardhat-ignition-ethers",
    "@typechain/ethers-v6": "$@typechain/ethers-v6",
    "@typechain/hardhat": "$@typechain/hardhat",
    "hardhat-gas-reporter": "$hardhat-gas-reporter"
  }
}
