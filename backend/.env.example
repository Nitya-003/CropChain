# ==============================================================================
# ENVIRONMENT VARIABLES FOR CROPCHAIN BACKEND
# ==============================================================================
# Copy this file to .env and fill in the required values for local development

### Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

### CORS & Rate Limiting
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
BATCH_RATE_LIMIT_MAX=20

### Database Configuration
MONGODB_URI=mongodb://localhost:27017/cropchain

### Authentication
JWT_SECRET=your_jwt_secret_here

### Blockchain & Web3
INFURA_URL=
CONTRACT_ADDRESS=
PRIVATE_KEY=

### Oracle Service Configuration
ORACLE_PRIVATE_KEY=
PROVIDER_URL=http://localhost:8545

### AI & External Services
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

### Optional Third-Party Services
ALCHEMY_URL=
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

### File Upload Configuration
MAX_FILE_SIZE=10485760

### Gas Reporting & Analytics
REPORT_GAS=false
COINMARKETCAP_API_KEY=

### Block Explorer API Keys
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
