# Existing environment variables
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# CORS configuration (comma-separated, exact protocol required, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
BATCH_RATE_LIMIT_MAX=20

# Blockchain configuration (Required for production, optional for CI)
INFURA_URL=
CONTRACT_ADDRESS=
PRIVATE_KEY=

# Oracle Service Configuration (Required for IoT functionality)
ORACLE_PRIVATE_KEY=
PROVIDER_URL=http://localhost:8545

# Optional Services
ALCHEMY_URL=
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Database configuration (optional, has fallback)
MONGODB_URI=mongodb://localhost:27017/cropchain

# Authentication (has fallback for CI)
JWT_SECRET=your_jwt_secret_here

# AI Chatbot Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# AI_MODEL=gpt-4o-mini
# AI_MAX_TOKENS=500
# AI_TEMPERATURE=0.7

# File upload configuration
MAX_FILE_SIZE=10485760

# Gas reporting (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# Block explorer API keys (optional)
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
