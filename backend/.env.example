# ==============================================================================
# ENVIRONMENT VARIABLES FOR CROPCHAIN BACKEND
# ==============================================================================
# Copy this file to .env and fill in the required values for local development

### Server Configuration

# Description: Port number on which the backend server will run
# Requirement: [Required] for local development
# Format: Integer (3000-65535)
# Source: Choose any available port, default is 3001
PORT=3001

# Description: Node.js environment mode
# Requirement: [Required] for proper application behavior
# Format: String (development, production, test)
# Source: Set to 'development' for local dev, 'production' for deployment
NODE_ENV=development

# Description: URL of the frontend application
# Requirement: [Required] for CORS and API communication
# Format: Full URL with protocol (e.g., http://localhost:5173)
# Source: Use your frontend dev server URL
FRONTEND_URL=http://localhost:5173

### CORS & Rate Limiting

# Description: Comma-separated list of allowed origins for CORS
# Requirement: [Required] for security and frontend communication
# Format: Comma-separated URLs, no spaces (e.g., http://localhost:3000,http://localhost:5173)
# Source: Add all frontend URLs that need API access
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Description: Time window for rate limiting in milliseconds
# Requirement: [Required] for rate limiting functionality
# Format: Integer in milliseconds (default: 900000 = 15 minutes)
# Source: Adjust based on desired rate limiting window
RATE_LIMIT_WINDOW_MS=900000

# Description: Maximum requests per window for general API
# Requirement: [Required] for rate limiting
# Format: Integer (number of requests)
# Source: Set based on expected traffic (default: 100 requests per 15 minutes)
RATE_LIMIT_MAX_REQUESTS=100

# Description: Maximum authentication attempts per window
# Requirement: [Required] for auth endpoint protection
# Format: Integer (number of attempts)
# Source: Set lower than general limit for security (default: 5)
AUTH_RATE_LIMIT_MAX=5

# Description: Maximum batch creation requests per window
# Requirement: [Required] for batch endpoint protection
# Format: Integer (number of requests)
# Source: Set based on expected batch creation frequency (default: 20)
BATCH_RATE_LIMIT_MAX=20

### Database Configuration

# Description: MongoDB connection string for the database
# Requirement: [Required] for production, [Optional] for local dev (has fallback)
# Format: MongoDB URI (mongodb://host:port/database)
# Source: Install MongoDB locally or get from MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/cropchain

### Authentication

# Description: Secret key for JWT token signing and verification
# Requirement: [Required] for production, [Optional] for CI (has fallback)
# Format: String (minimum 32 characters recommended)
# Source: Generate secure random string: `openssl rand -hex 32`
JWT_SECRET=your_jwt_secret_here

### Blockchain & Web3

# Description: Infura RPC URL for blockchain interaction
# Requirement: [Required] for production, [Optional] for local development
# Format: Full Infura URL with API key (e.g., https://polygon-mumbai.infura.io/v3/YOUR_KEY)
# Source: Create free account at https://infura.io/
INFURA_URL=

# Description: Deployed smart contract address
# Requirement: [Required] for production blockchain functionality
# Format: Ethereum address (0x followed by 40 hexadecimal characters)
# Source: Get from contract deployment or project documentation
CONTRACT_ADDRESS=

# Description: Private key for blockchain transactions
# Requirement: [Required] for production, [Optional] for CI (use test key)
# Format: 64-character hexadecimal string (without 0x prefix)
# Source: Generate new wallet or use existing private key (NEVER use real funds in dev)
PRIVATE_KEY=

### Oracle Service Configuration

# Description: Private key for oracle service (IoT data verification)
# Requirement: [Required] for IoT functionality
# Format: 64-character hexadecimal string (without 0x prefix)
# Source: Generate separate wallet for oracle service
ORACLE_PRIVATE_KEY=

# Description: Local blockchain provider URL for oracle
# Requirement: [Required] for oracle service
# Format: Full URL (e.g., http://localhost:8545)
# Source: Use local Hardhat node or Ganache
PROVIDER_URL=http://localhost:8545

### AI & External Services

# Description: OpenAI API key for AI chatbot functionality
# Requirement: [Optional] for AI features
# Format: String starting with 'sk-'
# Source: Create account at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Description: OpenAI model to use for chatbot responses
# Requirement: [Optional] defaults to gpt-4o-mini if not set
# Format: String (model name like gpt-4, gpt-3.5-turbo, gpt-4o-mini)
# Source: Available models at https://platform.openai.com/docs/models
AI_MODEL=gpt-4o-mini

# Description: Maximum tokens for AI response generation
# Requirement: [Optional] defaults to 500 if not set
# Format: Integer (1-4096 depending on model)
# Source: Adjust based on desired response length and cost
AI_MAX_TOKENS=500

# Description: Temperature for AI response creativity
# Requirement: [Optional] defaults to 0.7 if not set
# Format: Float between 0.0 and 2.0
# Source: 0.0 = deterministic, 1.0 = balanced, 2.0 = creative
AI_TEMPERATURE=0.7

### Optional Third-Party Services

# Description: Alchemy API URL for enhanced blockchain services
# Requirement: [Optional] for enhanced blockchain features
# Format: Full Alchemy URL with API key
# Source: Create account at https://www.alchemy.com/
ALCHEMY_URL=

# Description: Pinata API key for IPFS file storage
# Requirement: [Optional] for decentralized file storage
# Format: String (API key from Pinata)
# Source: Create account at https://www.pinata.cloud/
PINATA_API_KEY=

# Description: Pinata secret API key for IPFS operations
# Requirement: [Optional] if using Pinata
# Format: String (secret key from Pinata)
# Source: Get from Pinata dashboard after API key creation
PINATA_SECRET_API_KEY=

### File Upload Configuration

# Description: Maximum file size for uploads in bytes
# Requirement: [Required] for file upload functionality
# Format: Integer in bytes (default: 10485760 = 10MB)
# Source: Set based on your storage limits and requirements
MAX_FILE_SIZE=10485760

### Gas Reporting & Analytics

# Description: Enable/disable gas usage reporting
# Requirement: [Optional] for development monitoring
# Format: Boolean (true/false)
# Source: Set to true to track gas costs during development
REPORT_GAS=false

# Description: CoinMarketCap API key for price data
# Requirement: [Optional] for price conversion features
# Format: String (API key from CoinMarketCap)
# Source: Create account at https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=

### Block Explorer API Keys

# Description: PolygonScan API key for transaction verification
# Requirement: [Optional] for enhanced transaction tracking
# Format: String (API key from PolygonScan)
# Source: Create account at https://polygonscan.com/apis
POLYGONSCAN_API_KEY=

# Description: Etherscan API key for Ethereum transaction verification
# Requirement: [Optional] for Ethereum mainnet interactions
# Format: String (API key from Etherscan)
# Source: Create account at https://etherscan.io/apis
ETHERSCAN_API_KEY=
