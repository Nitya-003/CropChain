{
  "name": "cropchain-backend",
  "version": "1.0.0",
  "description": "Backend API for CropChain blockchain crop tracking system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required for serverless Node.js backend'",
