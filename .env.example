# Copy this file to .env and fill in the values locally, or inject the same variables from your CI/CD secret manager at runtime.

# Frontend public API endpoint
NEXT_PUBLIC_API_URL=http://cropapi.sonusid.in

# Backend runtime
NODE_ENV=production
PORT=3001
MONGODB_URI=mongodb://db:27017/cropchain
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Blockchain (required by backend)
INFURA_URL=https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
CONTRACT_ADDRESS=0x2c79F3f6b448270ADF667CA5d23d23feC4d15Fa4
PRIVATE_KEY=0xsdusdhjsdi

# Optional frontend flag
NEXT_PUBLIC_DEV_MODE=false
